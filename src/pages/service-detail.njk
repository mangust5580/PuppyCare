<!doctype html>
<html class="page" lang="ru">
  {%- set pageTitle = "Терапия для собак и кошек — PuppyCare" -%}
  {%- set pageDescription = "Диагностика, лечение и профилактика заболеваний у собак и кошек в ветеринарной клинике PuppyCare." -%}
  {%- set pageRobots = "index, follow" -%}
  {%- set pagePath = "service-detail.html" -%}
  {% include "shared/head/index.njk" %}

  <body data-page="service-therapy">
    {% include "shared/layout/skip-link.njk" %}
    {% include "shared/layout/header.njk" %}

    {% from "shared/components/picture.njk" import picture %}
    {% from "shared/components/button.njk" import button %}
    {% from "shared/components/accordion.njk" import accordion %}
    {% from "shared/components/icon.njk" import icon %}
    {% from "shared/sections/final-cta.njk" import finalCta %}

    {% set indicationsList = [
      "снижение аппетита",
      "вялость или необычное поведение",
      "кашель, чихание или выделения",
      "проблемы с пищеварением",
      "температура или болезненность",
      "плановый профилактический осмотр"
    ] %}

    {% set includedCards = [
      { title: "Осмотр и сбор анамнеза", text: "Врач уточняет симптомы, образ жизни питомца и историю заболеваний.", icon: "common-clipboard" },
      { title: "Первичная диагностика", text: "При необходимости назначаются анализы или дополнительные исследования.", icon: "medical-activity" },
      { title: "План лечения", text: "Вы получаете понятные рекомендации по лечению и уходу дома.", icon: "common-square-check" },
      { title: "Контроль состояния", text: "Врач объясняет, когда нужен повторный осмотр и на что обратить внимание.", icon: "common-refresh" }
    ] %}

    {% set processSteps = [
      { title: "Запись", text: "Вы выбираете удобное время онлайн или по телефону, а мы подсказываем, что взять с собой." },
      { title: "Осмотр", text: "Врач бережно осматривает питомца, уточняет симптомы и задаёт вопросы о состоянии." },
      { title: "Рекомендации", text: "Мы объясняем диагноз, план лечения и дальнейшие действия простым языком." },
      { title: "Поддержка", text: "При необходимости остаёмся на связи после приёма и приглашаем на контрольный осмотр." }
    ] %}

    {% set preparationList = [
      "возьмите ветеринарный паспорт",
      "запишите симптомы и дату их появления",
      "не давайте новые препараты без консультации",
      "если есть анализы — принесите результаты",
      "для кошек используйте переноску",
      "возьмите любимое лакомство, если питомец волнуется"
    ] %}

    {% set faqItems = [
      {
        question: "Нужно ли сдавать анализы перед приёмом?",
        answer: "Нет, обычно терапевт сначала проводит осмотр и только потом рекомендует анализы, если они действительно нужны. Если у вас уже есть результаты исследований, возьмите их с собой.",
        open: true
      },
      {
        question: "Можно ли прийти без записи?",
        answer: "Мы рекомендуем записываться заранее, чтобы не ждать в очереди. Если ситуация срочная, позвоните в клинику — администратор подскажет ближайшее доступное время."
      },
      {
        question: "Что делать, если питомцу стало хуже ночью?",
        answer: "Позвоните в клинику или ближайшую круглосуточную ветеринарную службу. Если есть затруднённое дыхание, судороги, сильная боль или потеря сознания, нужна срочная помощь."
      }
    ] %}

    {% set relatedServices = [
      {
        title: "Вакцинация",
        text: "Защита от инфекций с подбором безопасной схемы вакцинации для собак и кошек.",
        image: "images/pages/services/vaccination.jpg",
        imageAlt: "Ветеринар PuppyCare готовит питомца к вакцинации",
        href: "service-detail.html"
      },
      {
        title: "Диагностика и анализы",
        text: "Лабораторные исследования и диагностика, которые помогают быстрее понять причину недомогания.",
        image: "images/pages/services/diagnostics.jpg",
        imageAlt: "Диагностическое оборудование ветеринарной клиники PuppyCare",
        href: "service-detail.html"
      },
      {
        title: "Хирургия",
        text: "Плановые и экстренные операции с современным оборудованием и внимательным послеоперационным уходом.",
        image: "images/pages/services/surgery.jpg",
        imageAlt: "Подготовленная операционная ветеринарной клиники PuppyCare",
        href: "service-detail.html"
      }
    ] %}

    <main id="main" class="page__content page-service-detail" tabindex="-1" data-page-content>

      <section class="page-service-detail__hero" aria-labelledby="service-detail-title">

        <span class="page-service-detail__hero-decor" aria-hidden="true">
          <svg class="page-service-detail__decor page-service-detail__decor--paw" viewBox="0 0 64 64" fill="currentColor"><circle cx="18" cy="26" r="6"/><circle cx="30" cy="18" r="6"/><circle cx="44" cy="18" r="6"/><circle cx="50" cy="30" r="6"/><path d="M34 32c8 0 14 6 14 12 0 5-4 8-9 8-2 0-4-1-5-1s-3 1-5 1c-5 0-9-3-9-8 0-6 6-12 14-12z"/></svg>
          <svg class="page-service-detail__decor page-service-detail__decor--heart" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linejoin="round"><path d="M16 27S4 19.4 4 11.8A6.2 6.2 0 0 1 16 8.6 6.2 6.2 0 0 1 28 11.8C28 19.4 16 27 16 27z"/></svg>
          <svg class="page-service-detail__decor page-service-detail__decor--line" viewBox="0 0 200 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="2 12"><path d="M2 8h196"/></svg>
        </span>

        <div class="container page-service-detail__hero-inner">

          <div class="page-service-detail__hero-content">

            <p class="page-service-detail__eyebrow">Услуга</p>

            <h1 class="page-service-detail__title" id="service-detail-title">Терапия для собак и кошек</h1>

            <nav class="page-service-detail__breadcrumbs" aria-label="Хлебные крошки">
              <ol class="page-service-detail__breadcrumbs-list" role="list">
                <li class="page-service-detail__breadcrumbs-item">
                  <a class="page-service-detail__breadcrumbs-link" href="index.html">Главная</a>
                </li>
                <li class="page-service-detail__breadcrumbs-item">
                  <a class="page-service-detail__breadcrumbs-link" href="services.html">Услуги</a>
                </li>
                <li class="page-service-detail__breadcrumbs-item">
                  <span class="page-service-detail__breadcrumbs-current" aria-current="page">Терапия</span>
                </li>
              </ol>
            </nav>

            <p class="page-service-detail__lead">Диагностика, лечение и профилактика заболеваний у питомцев с внимательным подходом и заботой на каждом этапе.</p>

          </div>

          <div class="page-service-detail__hero-media">
            <span class="page-service-detail__hero-glow" aria-hidden="true"></span>
            {{ picture({
              src: "images/pages/service-detail/hero.jpg",
              alt: "",
              width: "2400",
              height: "900",
              className: "page-service-detail__hero-image",
              pictureClass: "page-service-detail__hero-picture",
              loading: "eager",
              decoding: "async",
              fetchpriority: "high",
              retina: true
            }) }}
          </div>

        </div>
      </section>

      <section class="page-service-detail__summary" aria-labelledby="service-summary-title">
        <div class="container">

          <h2 class="page-service-detail__summary-title" id="service-summary-title">Кратко об услуге</h2>

          <ul class="page-service-detail__summary-grid" role="list">

            <li class="page-service-detail__summary-item">
              <article class="page-service-detail__fact">
                <span class="page-service-detail__fact-icon" aria-hidden="true">
                  {{ icon("common-clock", decorative=true) }}
                </span>
                <p class="page-service-detail__fact-label">Длительность</p>
                <p class="page-service-detail__fact-value">от 30 минут</p>
              </article>
            </li>

            <li class="page-service-detail__summary-item">
              <article class="page-service-detail__fact">
                <span class="page-service-detail__fact-icon" aria-hidden="true">
                  {{ icon("pets-paw", decorative=true) }}
                </span>
                <p class="page-service-detail__fact-label">Подходит</p>
                <p class="page-service-detail__fact-value">собакам и кошкам</p>
              </article>
            </li>

            <li class="page-service-detail__summary-item">
              <article class="page-service-detail__fact">
                <span class="page-service-detail__fact-icon" aria-hidden="true">
                  {{ icon("common-calendar-check", decorative=true) }}
                </span>
                <p class="page-service-detail__fact-label">Запись</p>
                <p class="page-service-detail__fact-value">онлайн или телефон</p>
              </article>
            </li>

            <li class="page-service-detail__summary-item">
              <article class="page-service-detail__fact">
                <span class="page-service-detail__fact-icon" aria-hidden="true">
                  {{ icon("common-receipt", decorative=true) }}
                </span>
                <p class="page-service-detail__fact-label">Стоимость</p>
                <p class="page-service-detail__fact-value">от 1 500 ₽</p>
              </article>
            </li>

          </ul>

        </div>
      </section>

      <section class="page-service-detail__indications" aria-labelledby="service-indications-title">
        <div class="container page-service-detail__indications-layout">

          <div class="page-service-detail__indications-content">
            <p class="page-service-detail__eyebrow page-service-detail__eyebrow--dark">Когда обращаться</p>
            <h2 class="page-service-detail__indications-title" id="service-indications-title">Когда стоит обратиться к терапевту</h2>
            <p class="page-service-detail__indications-text">Терапевт помогает выявить причины недомогания, назначить лечение и подобрать профилактику, чтобы питомец быстрее вернулся к активной жизни.</p>

            <ul class="page-service-detail__checklist" role="list">
              {%- for item in indicationsList %}
              <li class="page-service-detail__checklist-item">
                <span class="page-service-detail__checklist-icon" aria-hidden="true">
                  {{ icon("common-check", decorative=true) }}
                </span>
                <span class="page-service-detail__checklist-text">{{ item }}</span>
              </li>
              {%- endfor %}
            </ul>
          </div>

          <aside class="page-service-detail__appointment" aria-labelledby="service-appointment-title">
            <h3 class="page-service-detail__appointment-title" id="service-appointment-title">Записаться на терапию</h3>
            <p class="page-service-detail__appointment-text">Подберём удобное время и расскажем, как подготовить питомца к визиту.</p>

            <dl class="page-service-detail__appointment-info">
              <div class="page-service-detail__appointment-row">
                <dt class="page-service-detail__appointment-label">Телефон</dt>
                <dd class="page-service-detail__appointment-value">
                  <a class="page-service-detail__appointment-phone" href="tel:+74951204567">+7 (495) 120-45-67</a>
                </dd>
              </div>
              <div class="page-service-detail__appointment-row">
                <dt class="page-service-detail__appointment-label">Ежедневно</dt>
                <dd class="page-service-detail__appointment-value">9:00–21:00</dd>
              </div>
            </dl>

            <div class="page-service-detail__appointment-actions">
              {{ button("Записаться на приём", tag="a", href="appointment.html", variant="primary", size="large") }}
            </div>
          </aside>

        </div>
      </section>

      <section class="page-service-detail__included" aria-labelledby="service-included-title">
        <div class="container">

          <div class="page-service-detail__included-head">
            <p class="page-service-detail__eyebrow page-service-detail__eyebrow--dark">Что входит</p>
            <h2 class="page-service-detail__included-title" id="service-included-title">Что входит в приём</h2>
            <p class="page-service-detail__included-text">Приём построен так, чтобы врач мог внимательно оценить состояние питомца и дать понятные рекомендации владельцу.</p>
          </div>

          <ul class="page-service-detail__included-grid" role="list">
            {%- for card in includedCards %}
            <li class="page-service-detail__included-item">
              <article class="page-service-detail__step">
                <span class="page-service-detail__step-icon" aria-hidden="true">{{ icon(card.icon, decorative=true) }}</span>
                <h3 class="page-service-detail__step-title">{{ card.title }}</h3>
                <p class="page-service-detail__step-text">{{ card.text }}</p>
              </article>
            </li>
            {%- endfor %}
          </ul>

        </div>
      </section>

      <section class="page-service-detail__process" aria-labelledby="service-process-title">
        <div class="container page-service-detail__process-layout">

          <div class="page-service-detail__process-content">
            <p class="page-service-detail__eyebrow page-service-detail__eyebrow--dark">Этапы приёма</p>
            <h2 class="page-service-detail__process-title" id="service-process-title">Как проходит приём</h2>
            <p class="page-service-detail__process-text">Мы выстроили процесс так, чтобы питомцу было спокойно, а владелец понимал каждый следующий шаг.</p>

            <ol class="page-service-detail__process-steps" role="list">
              {%- for step in processSteps %}
              <li class="page-service-detail__process-step">
                <span class="page-service-detail__process-marker" aria-hidden="true">{{ loop.index }}</span>
                <div class="page-service-detail__process-step-body">
                  <h3 class="page-service-detail__process-step-title">{{ step.title }}</h3>
                  <p class="page-service-detail__process-step-text">{{ step.text }}</p>
                </div>
              </li>
              {%- endfor %}
            </ol>
          </div>

          <div class="page-service-detail__process-media">
            {{ picture({
              src: "images/pages/services/therapy/process.jpg",
              alt: "Ветеринар PuppyCare объясняет владельцу план лечения питомца",
              width: "560",
              height: "420",
              className: "page-service-detail__process-image",
              pictureClass: "page-service-detail__process-picture",
              loading: "lazy",
              decoding: "async",
              retina: true
            }) }}
          </div>

        </div>
      </section>

      <section class="page-service-detail__preparation" aria-labelledby="service-preparation-title">
        <div class="container page-service-detail__preparation-layout">

          <div class="page-service-detail__preparation-content">
            <p class="page-service-detail__eyebrow page-service-detail__eyebrow--dark">Подготовка</p>
            <h2 class="page-service-detail__preparation-title" id="service-preparation-title">Как подготовиться к визиту</h2>
            <p class="page-service-detail__preparation-text">Несколько простых шагов помогут врачу быстрее разобраться в ситуации, а питомцу — чувствовать себя спокойнее на приёме.</p>
          </div>

          <div class="page-service-detail__preparation-card">
            <ul class="page-service-detail__preparation-list" role="list">
              {%- for item in preparationList %}
              <li class="page-service-detail__preparation-item">
                <span class="page-service-detail__preparation-check" aria-hidden="true">
                  {{ icon("common-check", decorative=true) }}
                </span>
                <span class="page-service-detail__preparation-item-text">{{ item }}</span>
              </li>
              {%- endfor %}
            </ul>
          </div>

          <aside class="page-service-detail__preparation-note" aria-labelledby="service-preparation-note-title">
            <span class="page-service-detail__preparation-note-icon" aria-hidden="true">
              {{ icon("common-info", decorative=true) }}
            </span>
            <div class="page-service-detail__preparation-note-body">
              <h3 class="page-service-detail__preparation-note-title" id="service-preparation-note-title">Важно</h3>
              <p class="page-service-detail__preparation-note-text">Если состояние питомца резко ухудшилось, лучше позвонить в клинику заранее — мы подскажем, как действовать до приезда.</p>
              <a class="page-service-detail__preparation-note-phone" href="tel:+74951204567">
                <span class="page-service-detail__preparation-note-phone-icon" aria-hidden="true">
                  {{ icon("contact-phone-handset", decorative=true) }}
                </span>
                +7 (495) 120-45-67
              </a>
            </div>
          </aside>

        </div>
      </section>

      <section class="page-service-detail__faq" aria-labelledby="service-faq-title">
        <div class="container page-service-detail__faq-layout">

          <div class="page-service-detail__faq-content">

            <div class="page-service-detail__faq-head">
              <p class="page-service-detail__eyebrow page-service-detail__eyebrow--dark">FAQ</p>
              <h2 class="page-service-detail__faq-title" id="service-faq-title">Частые вопросы</h2>
              <p class="page-service-detail__faq-text">Собрали ответы на вопросы, которые чаще всего возникают перед терапевтическим приёмом.</p>
            </div>

            <div class="page-service-detail__faq-body">
              {{ accordion({
                id: "therapy-faq",
                mode: "single",
                items: faqItems
              }) }}
            </div>

          </div>

          <div class="page-service-detail__faq-media">
            {{ picture({
              src: "images/pages/services/therapy/faq.jpg",
              alt: "Ветеринар PuppyCare отвечает на вопросы владельца питомца",
              width: "520",
              height: "520",
              className: "page-service-detail__faq-image",
              pictureClass: "page-service-detail__faq-picture",
              loading: "lazy",
              decoding: "async",
              retina: true
            }) }}
          </div>

        </div>
      </section>

      <section class="page-service-detail__related" aria-labelledby="service-related-title">
        <div class="container">

          <div class="page-service-detail__related-head">
            <p class="page-service-detail__eyebrow page-service-detail__eyebrow--dark">Другие услуги</p>
            <h2 class="page-service-detail__related-title" id="service-related-title">Вам также может подойти</h2>
            <p class="page-service-detail__related-text">Если питомцу нужна дополнительная помощь, посмотрите другие направления PuppyCare.</p>
          </div>

          <ul class="page-service-detail__related-grid" role="list">
            {%- for service in relatedServices %}
            <li class="page-service-detail__related-item">
              <article class="page-service-detail__related-card">
                <div class="page-service-detail__related-media">
                  {{ picture({
                    src: service.image,
                    alt: service.imageAlt,
                    width: "360",
                    height: "240",
                    className: "page-service-detail__related-image",
                    pictureClass: "page-service-detail__related-picture",
                    loading: "lazy",
                    decoding: "async",
                    retina: true
                  }) }}
                </div>
                <div class="page-service-detail__related-body">
                  <h3 class="page-service-detail__related-card-title">{{ service.title }}</h3>
                  <p class="page-service-detail__related-card-text">{{ service.text }}</p>
                  <a class="page-service-detail__related-link" href="{{ service.href }}">Подробнее →</a>
                </div>
              </article>
            </li>
            {%- endfor %}
          </ul>

        </div>
      </section>

      {{ finalCta({
        id: "service-cta",
        eyebrow: "Запись на приём",
        title: "Нужна консультация терапевта?",
        text: "Запишитесь на приём — мы внимательно осмотрим питомца и подскажем, что делать дальше.",
        image: "images/pages/services/therapy/cta-banner.jpg",
        imageAlt: "Ветеринар PuppyCare заботится о собаке перед приёмом",
        primaryText: "Записаться на приём",
        primaryHref: "appointment.html"
      }) }}

    </main>

    {% include "shared/layout/footer.njk" %}
  </body>
</html>
