<!doctype html>
<html class="page" lang="ru">
  {%- set pageTitle = "Контакты — PuppyCare" -%}
  {%- set pageDescription = "Контакты ветеринарной клиники PuppyCare: телефон, email, адрес, режим работы и форма обратной связи." -%}
  {%- set pageRobots = "index, follow" -%}
  {%- set pagePath = "contacts.html" -%}
  {% include "shared/head/index.njk" %}

  <body data-page="contacts">
    {% include "shared/layout/skip-link.njk" %}
    {% include "shared/layout/header.njk" %}

    {% from "shared/components/picture.njk" import picture %}
    {% from "shared/components/icon.njk" import icon %}
    {% from "shared/components/button.njk" import button %}
    {% from "shared/components/form-field.njk" import field, textarea, select %}
    {% from "shared/forms/feedback-form.njk" import feedbackForm %}

    <main id="main" class="page__content page-contacts" tabindex="-1" data-page-content>

      <section class="page-contacts__hero" aria-labelledby="contacts-title">

        <span class="page-contacts__hero-decor" aria-hidden="true">
          <svg class="page-contacts__decor page-contacts__decor--paw" viewBox="0 0 64 64" fill="currentColor"><circle cx="18" cy="26" r="6"/><circle cx="30" cy="18" r="6"/><circle cx="44" cy="18" r="6"/><circle cx="50" cy="30" r="6"/><path d="M34 32c8 0 14 6 14 12 0 5-4 8-9 8-2 0-4-1-5-1s-3 1-5 1c-5 0-9-3-9-8 0-6 6-12 14-12z"/></svg>
          <svg class="page-contacts__decor page-contacts__decor--heart" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linejoin="round"><path d="M16 27S4 19.4 4 11.8A6.2 6.2 0 0 1 16 8.6 6.2 6.2 0 0 1 28 11.8C28 19.4 16 27 16 27z"/></svg>
          <svg class="page-contacts__decor page-contacts__decor--line" viewBox="0 0 200 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="2 12"><path d="M2 8h196"/></svg>
        </span>

        <div class="container page-contacts__hero-inner">

          <div class="page-contacts__hero-content">

            <p class="page-contacts__eyebrow">Свяжитесь с нами</p>

            <h1 class="page-contacts__title" id="contacts-title">Контакты</h1>

            <nav class="page-contacts__breadcrumbs" aria-label="Хлебные крошки">
              <ol class="page-contacts__breadcrumbs-list" role="list">
                <li class="page-contacts__breadcrumbs-item">
                  <a class="page-contacts__breadcrumbs-link" href="index.html">Главная</a>
                </li>
                <li class="page-contacts__breadcrumbs-item">
                  <span class="page-contacts__breadcrumbs-current" aria-current="page">Контакты</span>
                </li>
              </ol>
            </nav>

            <p class="page-contacts__lead">Мы рядом, чтобы помочь вам и вашему питомцу: ответим на вопросы, подскажем удобное время визита и расскажем, как нас найти.</p>

          </div>

          <div class="page-contacts__hero-media">
            <span class="page-contacts__hero-glow" aria-hidden="true"></span>
            {{ picture({
              src: "images/pages/contacts/hero.jpg",
              alt: "",
              width: "2400",
              height: "900",
              className: "page-contacts__hero-image",
              pictureClass: "page-contacts__hero-picture",
              loading: "eager",
              decoding: "async",
              fetchpriority: "high",
              retina: true
            }) }}
          </div>

        </div>
      </section>

      <section class="page-contacts__main" aria-labelledby="contacts-main-title">
        <div class="container">

          <div class="page-contacts__intro">
            <p class="page-contacts__intro-eyebrow">Контакты</p>
            <h2 class="page-contacts__intro-title" id="contacts-main-title">Свяжитесь с нами</h2>
            <p class="page-contacts__intro-text">Мы всегда готовы помочь вам и вашим питомцам. Запишитесь на приём, задайте вопрос или получите совет по уходу и лечению.</p>
          </div>

          <ul class="page-contacts__cards" role="list">
            <li>
              <a class="page-contacts__card" href="tel:+74951204567">
                <span class="page-contacts__card-icon" aria-hidden="true">{{ icon("contact-phone", size="md") }}</span>
                <span class="page-contacts__card-body">
                  <span class="page-contacts__card-title">Позвоните нам</span>
                  <span class="page-contacts__card-value">+7 (495) 120-45-67</span>
                </span>
              </a>
            </li>
            <li>
              <a class="page-contacts__card" href="mailto:info@puppycare.ru">
                <span class="page-contacts__card-icon" aria-hidden="true">{{ icon("contact-mail", size="md") }}</span>
                <span class="page-contacts__card-body">
                  <span class="page-contacts__card-title">Напишите нам</span>
                  <span class="page-contacts__card-value">info@puppycare.ru</span>
                </span>
              </a>
            </li>
            <li>
              <address class="page-contacts__card page-contacts__card--address">
                <span class="page-contacts__card-icon" aria-hidden="true">{{ icon("contact-location", size="md") }}</span>
                <span class="page-contacts__card-body">
                  <span class="page-contacts__card-title">Приезжайте</span>
                  <span class="page-contacts__card-value"><a class="page-contacts__card-address-link" href="https://yandex.com/maps/?text=%D0%9C%D0%BE%D1%81%D0%BA%D0%B2%D0%B0%2C%20%D1%83%D0%BB.%20%D0%9B%D0%B5%D1%81%D0%BD%D0%B0%D1%8F%2C%2010%2C%20%D0%BE%D1%84%D0%B8%D1%81%2025" target="_blank" rel="noopener noreferrer">г. Москва, ул. Лесная, д. 10, офис 25, 127055</a></span>
                </span>
              </address>
            </li>
          </ul>

          <div class="page-contacts__grid">

            <div class="page-contacts__form-card">
              <h3 class="page-contacts__block-title">Форма обратной связи</h3>
              {{ feedbackForm(
                idPrefix="contacts-feedback",
                className="page-contacts__form",
                action="contacts.html",
                submitClass="page-contacts__form-submit",
                noteClass="page-contacts__form-note",
                noteLinkClass="page-contacts__form-note-link"
              ) }}
            </div>

            <div class="page-contacts__info-card">
              <h3 class="page-contacts__block-title">Мы рядом и готовы помочь</h3>
              <div class="page-contacts__info-media">
                {{ picture({
                  src: "images/pages/contacts/contact-help.jpg",
                  alt: "Ветеринар PuppyCare общается с владельцем питомца в клинике",
                  width: "800",
                  height: "560",
                  className: "page-contacts__info-image",
                  pictureClass: "page-contacts__info-picture",
                  loading: "lazy",
                  decoding: "async",
                  retina: true
                }) }}
              </div>
              <ul class="page-contacts__info-list" role="list">
                <li class="page-contacts__info-item">
                  <span class="page-contacts__info-icon" aria-hidden="true">{{ icon("common-clock", size="sm") }}</span>
                  <div class="page-contacts__info-body">
                    <p class="page-contacts__info-title">Часы работы</p>
                    <p class="page-contacts__info-text">Ежедневно: 08:00–21:00</p>
                  </div>
                </li>
                <li class="page-contacts__info-item">
                  <span class="page-contacts__info-icon" aria-hidden="true">{{ icon("services-emergency", size="sm") }}</span>
                  <div class="page-contacts__info-body">
                    <p class="page-contacts__info-title">Срочная помощь</p>
                    <p class="page-contacts__info-text">24/7 по предварительному звонку</p>
                  </div>
                </li>
                <li class="page-contacts__info-item">
                  <span class="page-contacts__info-icon" aria-hidden="true">{{ icon("contact-mail", size="sm") }}</span>
                  <div class="page-contacts__info-body">
                    <p class="page-contacts__info-title">E-mail</p>
                    <p class="page-contacts__info-text"><a class="page-contacts__info-link" href="mailto:info@puppycare.ru">info@puppycare.ru</a></p>
                  </div>
                </li>
                <li class="page-contacts__info-item">
                  <span class="page-contacts__info-icon" aria-hidden="true">{{ icon("contact-phone", size="sm") }}</span>
                  <div class="page-contacts__info-body">
                    <p class="page-contacts__info-title">Телефон</p>
                    <p class="page-contacts__info-text"><a class="page-contacts__info-link" href="tel:+74951204567">+7 (495) 120-45-67</a></p>
                  </div>
                </li>
              </ul>
              <p class="page-contacts__note">
                <span class="page-contacts__note-icon" aria-hidden="true">{{ icon("common-heart", size="sm") }}</span>
                <span>Забота и внимание к каждому питомцу — наша главная миссия. Мы всегда на связи!</span>
              </p>
            </div>

          </div>

        </div>
      </section>

      <section class="page-contacts__map-section" aria-labelledby="contacts-map-title">
        <div class="container">

          <div class="page-contacts__map-header">
            <p class="page-contacts__intro-eyebrow">Как нас найти</p>
            <h2 class="page-contacts__intro-title" id="contacts-map-title">Мы ждём вас в PuppyCare</h2>
            <p class="page-contacts__intro-text">Клиника находится рядом с удобными транспортными маршрутами. Перед визитом можно позвонить нам — администратор подскажет, как быстрее добраться и где припарковаться.</p>
          </div>

          <div class="page-contacts__map-layout">
            <div class="page-contacts__map-frame">
              {{ picture({
                src: "images/pages/contacts/contact-map.jpg",
                alt: "Схематичная карта района с отметкой клиники PuppyCare",
                width: "800",
                height: "400",
                className: "page-contacts__map-image",
                pictureClass: "page-contacts__map-picture",
                loading: "lazy",
                decoding: "async",
                retina: true
              }) }}
            </div>

            <div class="page-contacts__map-card">
              <h3 class="page-contacts__map-card-title">Контактная информация</h3>
              <ul class="page-contacts__map-list" role="list">
                <li class="page-contacts__map-item">
                  <span class="page-contacts__map-icon" aria-hidden="true">{{ icon("contact-location", size="sm") }}</span>
                  <span class="page-contacts__map-content">
                    <span class="page-contacts__map-label">Адрес клиники</span>
                    <address class="page-contacts__map-value">
                      <a class="page-contacts__map-address-link" href="https://yandex.com/maps/?text=%D0%9C%D0%BE%D1%81%D0%BA%D0%B2%D0%B0%2C%20%D1%83%D0%BB.%20%D0%9B%D0%B5%D1%81%D0%BD%D0%B0%D1%8F%2C%2010%2C%20%D0%BE%D1%84%D0%B8%D1%81%2025" target="_blank" rel="noopener noreferrer">г. Москва, ул. Лесная, д. 10, офис 25, 127055</a>
                    </address>
                  </span>
                </li>
                <li class="page-contacts__map-item">
                  <span class="page-contacts__map-icon" aria-hidden="true">{{ icon("common-clock", size="sm") }}</span>
                  <span class="page-contacts__map-content">
                    <span class="page-contacts__map-label">Режим работы</span>
                    <span class="page-contacts__map-value">Ежедневно: 08:00–21:00</span>
                  </span>
                </li>
                <li class="page-contacts__map-item">
                  <span class="page-contacts__map-icon" aria-hidden="true">{{ icon("contact-phone", size="sm") }}</span>
                  <span class="page-contacts__map-content">
                    <span class="page-contacts__map-label">Телефон</span>
                    <a class="page-contacts__map-value page-contacts__map-link" href="tel:+74951204567">+7 (495) 120-45-67</a>
                  </span>
                </li>
                <li class="page-contacts__map-item">
                  <span class="page-contacts__map-icon" aria-hidden="true">{{ icon("contact-mail", size="sm") }}</span>
                  <span class="page-contacts__map-content">
                    <span class="page-contacts__map-label">E-mail</span>
                    <a class="page-contacts__map-value page-contacts__map-link" href="mailto:info@puppycare.ru">info@puppycare.ru</a>
                  </span>
                </li>
              </ul>
            </div>
          </div>

        </div>
      </section>

    </main>

    {% include "shared/layout/footer.njk" %}
  </body>
</html>
