{% from "shared/components/icon.njk" import icon %}

<footer class="site-footer">
  <div class="container">

    <div class="site-footer__top">

      <div class="site-footer__brand">
        <a class="site-footer__logo" href="index.html" aria-label="PuppyCare — на главную">
          <span class="site-footer__logo-mark" aria-hidden="true">{{ icon("pets-paw", decorative=true) }}</span>
          <span class="site-footer__logo-text">PuppyCare</span>
        </a>
        <p class="site-footer__text">Забота, которой можно доверять.</p>
        <ul class="site-footer__social" role="list">
          {%- for social in footer.socialLinks %}
          <li>
            <a class="site-footer__social-link" href="{{ social.url }}" aria-label="{{ social.label }}" target="_blank" rel="noopener noreferrer">{{ icon(social.icon, decorative=true) }}</a>
          </li>
          {%- endfor %}
        </ul>
      </div>

      <nav class="site-footer__column" aria-labelledby="footer-services-title">
        <h2 class="site-footer__title" id="footer-services-title">Услуги</h2>
        <ul class="site-footer__list" role="list">
          {%- for link in footer.servicesLinks %}
          <li><a class="site-footer__link" href="{{ link.href }}">{{ link.text }}</a></li>
          {%- endfor %}
        </ul>
      </nav>

      <nav class="site-footer__column" aria-labelledby="footer-company-title">
        <h2 class="site-footer__title" id="footer-company-title">Компания</h2>
        <ul class="site-footer__list" role="list">
          {%- for link in footer.companyLinks %}
          <li><a class="site-footer__link" href="{{ link.href }}">{{ link.text }}</a></li>
          {%- endfor %}
        </ul>
      </nav>

      <nav class="site-footer__column" aria-labelledby="footer-support-title">
        <h2 class="site-footer__title" id="footer-support-title">Поддержка</h2>
        <ul class="site-footer__list" role="list">
          {%- for link in footer.supportLinks %}
          <li><a class="site-footer__link" href="{{ link.href }}">{{ link.text }}</a></li>
          {%- endfor %}
        </ul>
      </nav>

      <div class="site-footer__contacts">
        <h2 class="site-footer__title">Контакты</h2>
        <ul class="site-footer__contact-list" role="list">
          <li class="site-footer__contact-item">
            <span class="site-footer__contact-icon" aria-hidden="true">{{ icon("contact-phone", decorative=true) }}</span>
            <a class="site-footer__contact-link" href="{{ contact.phone.href }}">{{ contact.phone.label }}</a>
          </li>
          <li class="site-footer__contact-item">
            <span class="site-footer__contact-icon" aria-hidden="true">{{ icon("contact-mail", decorative=true) }}</span>
            <a class="site-footer__contact-link" href="{{ contact.email.href }}">{{ contact.email.label }}</a>
          </li>
          <li class="site-footer__contact-item">
            <span class="site-footer__contact-icon" aria-hidden="true">{{ icon("contact-location", decorative=true) }}</span>
            <a class="site-footer__contact-link" href="{{ contact.address.href }}" target="_blank" rel="noopener noreferrer">{{ contact.address.shortLabel }}</a>
          </li>
          <li class="site-footer__contact-item">
            <span class="site-footer__contact-icon" aria-hidden="true">{{ icon("common-clock", decorative=true) }}</span>
            <span class="site-footer__contact-text">{{ contact.hours.shortLabel }}</span>
          </li>
        </ul>
      </div>

    </div>

    <div class="site-footer__divider" aria-hidden="true">
      <span class="site-footer__divider-icon">{{ icon("pets-paw", decorative=true) }}</span>
    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__copyright">© 2026 PuppyCare. Все права защищены.</p>
      <ul class="site-footer__legal" role="list">
        <li><a class="site-footer__legal-link" href="privacy.html">Политика конфиденциальности</a></li>
        <li><a class="site-footer__legal-link" href="terms.html">Пользовательское соглашение</a></li>
      </ul>
    </div>

  </div>
</footer>

{% include "shared/modals/index.njk" %}
