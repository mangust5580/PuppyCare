{% from "shared/components/button.njk" import button %}
{% from "shared/components/icon.njk" import icon %}
{%- set activePath = pagePath | default('index.html') -%}
{%- if activePath == '' -%}{%- set activePath = 'index.html' -%}{%- endif -%}
{%- set primaryNavigation = navigation.primary | default([]) -%}

<header class="site-header" data-js-header>
  <div class="container site-header__inner">

    <a class="site-header__logo" href="index.html" aria-label="PuppyCare — на главную">
      <img class="site-header__logo-image"
           src="images/logo.svg"
           alt="PuppyCare"
           width="158"
           height="40">
    </a>

    <nav class="site-header__nav" aria-label="Основная навигация">
      <ul class="site-header__nav-list" role="list">

        {%- for item in primaryNavigation %}
        {%- set itemActive = activePath in (item.matches | default([])) -%}
        {%- set groupActive = activePath in (item.activePaths | default([])) -%}
        <li class="site-header__nav-item{{ ' site-header__nav-item--has-dropdown' if item.items }}">
          {%- if item.items %}
          <button class="site-header__nav-link site-header__dropdown-toggle{{ ' site-header__nav-link--active' if groupActive }}"
                  type="button"
                  aria-expanded="false"
                  aria-controls="dropdown-{{ item.id }}"
                  data-js-header-dropdown-toggle>
            {{ item.label }}
            {{ icon("ui-chevron-down", className="site-header__chevron", size="sm") }}
          </button>
          <ul class="site-header__dropdown" id="dropdown-{{ item.id }}" role="list" data-js-header-dropdown>
            {%- for subitem in item.items %}
            {%- set subitemActive = activePath in (subitem.matches | default([subitem.href])) -%}
            <li>
              <a class="site-header__dropdown-link{{ ' site-header__dropdown-link--active' if subitemActive }}"
                 href="{{ subitem.href }}"
                 {% if subitemActive %}aria-current="page"{% endif %}
                 data-js-header-link>{{ subitem.label }}</a>
            </li>
            {%- endfor %}
          </ul>
          {%- else %}
          <a class="site-header__nav-link{{ ' site-header__nav-link--active' if itemActive }}"
             href="{{ item.href }}"
             {% if itemActive %}aria-current="page"{% endif %}
             data-js-header-link>{{ item.label }}</a>
          {%- endif %}
        </li>
        {%- endfor %}

      </ul>
    </nav>

    <div class="site-header__actions">
      <a class="site-header__phone" href="{{ contact.phone.href }}">
        {{ icon("contact-phone", className="site-header__phone-icon", size="sm") }}
        <span>{{ contact.phone.label }}</span>
      </a>
      {{ button("Записаться онлайн", tag="a", href="appointment.html", variant="primary", size="medium", extraClass="site-header__cta") }}
    </div>

    <button class="site-header__toggle"
            type="button"
            aria-label="Открыть меню"
            aria-controls="site-header-menu"
            aria-expanded="false"
            data-js-header-toggle>
      <span class="site-header__toggle-line"></span>
      <span class="site-header__toggle-line"></span>
      <span class="site-header__toggle-line"></span>
    </button>

  </div>

  <div class="site-header__mobile" id="site-header-menu" data-js-header-menu hidden>
    <div class="site-header__mobile-inner">

      <nav class="site-header__mobile-nav" aria-label="Мобильная навигация">
        <ul class="site-header__mobile-list" role="list">

          {%- for item in primaryNavigation %}
          {%- set itemActive = activePath in (item.matches | default([])) -%}
          {%- set groupActive = activePath in (item.activePaths | default([])) -%}
          <li class="site-header__mobile-item">
            {%- if item.items %}
            <span class="site-header__mobile-label{{ ' site-header__mobile-label--active' if groupActive }}">{{ item.label }}</span>
            <ul class="site-header__mobile-sub" role="list">
              {%- for subitem in item.items %}
              {%- set subitemActive = activePath in (subitem.matches | default([subitem.href])) -%}
              <li>
                <a class="site-header__mobile-sub-link{{ ' site-header__mobile-sub-link--active' if subitemActive }}"
                   href="{{ subitem.href }}"
                   {% if subitemActive %}aria-current="page"{% endif %}
                   data-js-header-link>{{ subitem.label }}</a>
              </li>
              {%- endfor %}
            </ul>
            {%- else %}
            <a class="site-header__mobile-link{{ ' site-header__mobile-link--active' if itemActive }}"
               href="{{ item.href }}"
               {% if itemActive %}aria-current="page"{% endif %}
               data-js-header-link>{{ item.label }}</a>
            {%- endif %}
          </li>
          {%- endfor %}

        </ul>
      </nav>

      <div class="site-header__mobile-actions">
        <a class="site-header__mobile-phone" href="{{ contact.phone.href }}">
          {{ icon("contact-phone", className="site-header__mobile-phone-icon", size="sm") }}
          <span>{{ contact.phone.label }}</span>
        </a>
        {{ button("Записаться онлайн", tag="a", href="appointment.html", variant="primary", size="medium", extraClass="site-header__mobile-cta") }}
      </div>

    </div>
  </div>

</header>
