{% endmacro %}


{# ── switchControl ────────────────────────────────────────────────────────── #}

{% macro switchControl(
  id        = '',
  name      = '',
  value     = '',
  label     = '',
  hint      = '',
  checked   = false,
  disabled  = false,
  required  = false,
  extraClass = ''
) %}

  {%- set _classes = [
    'choice-control',
    'choice-control--switch',
    ('choice-control--disabled' if disabled),
    (extraClass if extraClass)
  ] | select | join(' ') -%}

  <div class="{{ _classes }}">
    <label class="choice-control__label" for="{{ id }}">
      <input
        class="choice-control__input"
        type="checkbox"
        role="switch"
        id="{{ id }}"
        name="{{ name }}"
        {%- if value %} value="{{ value }}"{% endif %}
        {%- if hint %} aria-describedby="{{ id }}-hint"{% endif %}
        {%- if checked %} checked{% endif %}
        {%- if disabled %} disabled{% endif %}
        {%- if required %} required{% endif %}
      >
      <span class="choice-control__track" aria-hidden="true"><span class="choice-control__thumb"></span></span>
      {{- label }}
    </label>
    {%- if hint %}
    <span class="choice-control__hint" id="{{ id }}-hint">{{ hint }}</span>
    {%- endif %}
  </div>

{% endmacro %}


{# ── checkboxGroup ────────────────────────────────────────────────────────── #}

{% macro checkboxGroup(
  legend    = '',
  name      = '',
  options   = [],
  hint      = '',
  error     = '',
  required  = false,
  extraClass = ''
) %}

  {%- set _classes = [
    'choice-group',
    (extraClass if extraClass)
  ] | select | join(' ') -%}

  <fieldset class="{{ _classes }}">
    {%- if legend %}
    <legend class="choice-group__legend">{{ legend }}</legend>
    {%- endif %}
    {%- if hint %}
    <p class="choice-group__hint">{{ hint }}</p>
    {%- endif %}
    <ul class="choice-group__list">
      {%- for option in options %}
      <li>{{ checkbox(
        id       = name + '-' + loop.index,
        name     = name,
        value    = option.value,
        label    = option.label,
        hint     = option.hint if option.hint else '',
        checked  = option.checked if option.checked else false,
        disabled = option.disabled if option.disabled else false,
        required = required
      ) }}</li>
      {%- endfor %}
    </ul>
    {%- if error %}
    <p class="choice-group__error">{{ error }}</p>
    {%- endif %}
  </fieldset>

{% endmacro %}


{# ── radioGroup ───────────────────────────────────────────────────────────── #}

{% macro radioGroup(
  legend    = '',
  name      = '',
  options   = [],
  value     = '',
  hint      = '',
  error     = '',
  required  = false,
  extraClass = ''
) %}

  {%- set _classes = [
    'choice-group',
    (extraClass if extraClass)
  ] | select | join(' ') -%}

  <fieldset class="{{ _classes }}">
    {%- if legend %}
    <legend class="choice-group__legend">{{ legend }}</legend>
    {%- endif %}
    {%- if hint %}
    <p class="choice-group__hint">{{ hint }}</p>
    {%- endif %}
    <ul class="choice-group__list">
      {%- for option in options %}
      <li>{{ radio(
        id       = name + '-' + loop.index,
        name     = name,
        value    = option.value,
        label    = option.label,
        hint     = option.hint if option.hint else '',
        checked  = (option.value == value),
        disabled = option.disabled if option.disabled else false,
        required = required
      ) }}</li>
      {%- endfor %}
    </ul>
    {%- if error %}
    <p class="choice-group__error">{{ error }}</p>
    {%- endif %}
  </fieldset>

{% endmacro %}
